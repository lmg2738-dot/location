# ===========================================
# LocationAI 환경변수 (값은 Vercel/로컬 .env.local에만 설정)
# 이 파일은 Git에 커밋됩니다. 실제 키 값을 넣지 마세요.
# ===========================================

# 앱 설정
NEXT_PUBLIC_MOCK_MODE=false
NEXT_PUBLIC_APP_URL=http://localhost:60001

# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# OpenRouter (무료 모델만 자동 사용)
OPENROUTER_API_KEY=

# Kakao (developers.kakao.com)
KAKAO_REST_API_KEY=
NEXT_PUBLIC_KAKAO_MAP_KEY=

# 공공데이터 (data.go.kr) — 선택, 없으면 Mock
MOLIT_REAL_ESTATE_API_KEY=
SMALL_BUSINESS_API_KEY=
TOUR_API_KEY=
WEATHER_API_KEY=
